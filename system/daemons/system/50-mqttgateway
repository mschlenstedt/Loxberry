#!/bin/bash
GENERALJSON="$LBHOMEDIR/config/system/general.json"
GATEWAY_VERSION=$(python3 -c "import json,sys; d=json.load(open('$GENERALJSON')); print(d.get('Mqtt',{}).get('Gatewayversion',1))" 2>/dev/null || echo 1)
GATEWAY_AUTOSTART=$(python3 -c "import json,sys; d=json.load(open('$GENERALJSON')); v=d.get('Mqtt',{}).get('Gatewayautostart',1); print(0 if str(v) in ('0','false','False') else 1)" 2>/dev/null || echo 1)

if [ "$GATEWAY_AUTOSTART" = "0" ]; then
    exit 0
fi

# Do not start if no Miniserver with an IP address is configured
MS_CONFIGURED=$(python3 -c "
import json, sys
d = json.load(open('$GENERALJSON'))
ms = d.get('Miniserver', {})
ok = any(isinstance(v, dict) and v.get('Ipaddress','').strip() for v in ms.values())
print(1 if ok else 0)
" 2>/dev/null || echo 1)

if [ "$MS_CONFIGURED" = "0" ]; then
    exit 0
fi

if [ "$GATEWAY_VERSION" = "2" ]; then
    VENV="$LBHOMEDIR/sbin/mqttgateway_venv"
    GWLOGFILE="$LBHOMEDIR/log/system_tmpfs/mqtt-gateway.log"
    REQUIREMENTS="$LBHOMEDIR/sbin/mqtt_requirements.txt"

    # Check venv existence and package completeness; recreate if needed
    VENV_OK=0
    if [ -x "$VENV/bin/python3" ]; then
        "$VENV/bin/python3" -c "import aiomqtt, aiohttp" 2>/dev/null && VENV_OK=1
    fi

    if [ "$VENV_OK" = "0" ]; then
        echo "$(date) [50-mqttgateway] venv missing or incomplete, recreating..." >> "$GWLOGFILE"
        rm -rf "$VENV"
        python3 -m venv "$VENV" >> "$GWLOGFILE" 2>&1
        if [ -f "$REQUIREMENTS" ]; then
            "$VENV/bin/pip" install --quiet -r "$REQUIREMENTS" >> "$GWLOGFILE" 2>&1
        else
            "$VENV/bin/pip" install --quiet aiomqtt aiohttp >> "$GWLOGFILE" 2>&1
        fi
        chown -R loxberry:loxberry "$VENV"
    fi

    # Fix log file ownership so loxberry can append to it
    touch "$GWLOGFILE"
    chown loxberry:loxberry "$GWLOGFILE"

    su loxberry -c "$VENV/bin/python3 -u $LBHOMEDIR/sbin/mqtt_gateway.py >> $GWLOGFILE 2>&1 &"
else
    su loxberry -c "$LBHOMEDIR/sbin/mqttgateway.pl > /dev/null 2>&1 &"
fi
